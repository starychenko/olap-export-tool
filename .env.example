# ============================================================
# OLAP Export Tool - Секрети (.env)
# ============================================================
# Цей файл містить ТІЛЬКИ секретні налаштування (сервер, БД, автентифікація).
# Всі інші налаштування перенесені у config.yaml (див. config.yaml.example).
# ============================================================

# Параметри підключення до OLAP
OLAP_SERVER=10.40.0.48
OLAP_DATABASE=Sells

# Метод автентифікації: SSPI (Windows) або LOGIN (логін/пароль)
OLAP_AUTH_METHOD=LOGIN

# Домен для формування повного логіну (EPICENTRK\username)
OLAP_DOMAIN=EPICENTRK

# Шифрування збережених облікових даних
OLAP_CREDENTIALS_ENCRYPTED=true
OLAP_CREDENTIALS_FILE=.credentials

# Майстер-пароль (опційно)
OLAP_USE_MASTER_PASSWORD=false
# OLAP_MASTER_PASSWORD=

# ============================================================
# ClickHouse (опційно — для завантаження даних у ClickHouse)
# ============================================================

# Увімкнення завантаження у ClickHouse паралельно з Excel/CSV
CH_ENABLED=false

# Адреса та порт ClickHouse (443 — HTTPS, 8123 — HTTP)
CH_HOST=localhost
CH_PORT=443

# Автентифікація
CH_USERNAME=default
CH_PASSWORD=

# Використовувати HTTPS (true) або HTTP (false)
CH_SECURE=true

# База даних та таблиця для завантаження
CH_DATABASE=olap_export
CH_TABLE=sales

# ============================================================
# DuckDB REST API (опційно — для завантаження даних у DuckDB)
# ============================================================

# Увімкнення завантаження у DuckDB паралельно з Excel/CSV
DUCK_ENABLED=false

# URL REST API
DUCK_URL=https://analytics.lwhs.xyz

# API ключ автентифікації (X-API-Key header)
DUCK_API_KEY=

# Таблиця для завантаження
DUCK_TABLE=sales

# Кількість рядків на один INSERT statement (batch size)
DUCK_BATCH_SIZE=1000

# ============================================================
# PostgreSQL (опційно — для завантаження даних у PostgreSQL)
# ============================================================

# Увімкнення завантаження у PostgreSQL паралельно з Excel/CSV
PG_ENABLED=false

# Адреса та порт PostgreSQL
# З роботи (через інтернет): PG_HOST=db.lwhs.xyz, PG_PORT=54321
# З дому (LAN/VPN):          PG_HOST=192.168.1.111, PG_PORT=5432
PG_HOST=localhost
PG_PORT=5432

# База даних та автентифікація
PG_DATABASE=analytics
PG_USER=analytics
PG_PASSWORD=

# Schema та таблиця
PG_SCHEMA=public
PG_TABLE=sales

# SSL режим: require | verify-ca | verify-full | disable
# require — шифрування без перевірки сертифікату (підходить для self-signed)
PG_SSL_MODE=require
